data(election, package = "poLCA")
elec       <- election
elec.items <- colnames(election)[1:12]
# Recode to 0-based integers as required by multilevLCA
elec[, elec.items] <- lapply(elec[, elec.items], \(x) as.integer(x) - 1L)
# Centre AGE; recode GENDER to 0/1
elec$AGE    <- elec$AGE - mean(elec$AGE, na.rm = TRUE)
elec$GENDER <- elec$GENDER - 1L
elec$PARTY
data(election, package = "poLCA")
elec       <- election
elec.items <- colnames(election)[1:12]
# Recode to 0-based integers as required by multilevLCA
elec[, elec.items] <- lapply(elec[, elec.items], \(x) as.integer(x) - 1L)
elec.measurement <- three_step(
data       = elec,
Y.names    = elec.items,
n_classes  = 3,
incomplete = FALSE
)
elec.measurement$measurement_model$fit0
elec.measurement <- three_step(
data       = elec,
Y.names    = elec.items,
n_classes  = 3,
#The poLCA example drops any row with a missing cell
incomplete = TRUE
)
elec.measurement$measurement_model$fit0$vPi
elec.measurement <- three_step(
data       = elec,
Y.names    = elec.items,
n_classes  = 3,
#The poLCA example drops any row with a missing cell
incomplete = FALSE
)
elec.three_step <- three_step(
data       = elec,
Y.names    = elec.items,
n_classes  = 3,
Zp.names   = c("PARTY"),
step1      = elec.measurement$measurement_model,
incomplete = FALSE
)
summary(elec.three_step)
elec.three_step <- three_step(
data       = elec,
